# Port used by the Express API server (defaults to 4000 if not set)
API_PORT=4000

# Optional fallback for the API port in some deployment environments
PORT=4000

# PostgreSQL connection string for production (preferred)
# Example: postgresql://user:password@host:5432/infidash?sslmode=disable
DATABASE_URL=

# Optional SSL mode for the PostgreSQL client (e.g. disable, require)
DATABASE_SSL=disable


# Optional directory for database backups
INFIDASH_BACKUP_DIR=/data/backups

# Optional frontend/runtime settings
APP_URL=http://127.0.0.1:3000
